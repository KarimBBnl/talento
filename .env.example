# Configuración de la Aplicación
# Copia este archivo a .env.local y completa los valores

# Next.js
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Elijo Quedarme

# API
NEXT_PUBLIC_API_URL=http://localhost:3000/api
API_SECRET_KEY=tu_secret_key_aqui

# Base de datos (cuando se implemente)
DATABASE_URL=postgresql://user:password@localhost:5432/elijoquedarme

# Autenticación
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=tu_nextauth_secret_aqui

# Email (cuando se implemente notificaciones)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@gmail.com
SMTP_PASS=tu_password_aqui
SMTP_FROM=noreply@elijoquedarme.es

# Terceros (opcional)
GOOGLE_CLIENT_ID=tu_google_client_id
GOOGLE_CLIENT_SECRET=tu_google_client_secret

LINKEDIN_CLIENT_ID=tu_linkedin_client_id
LINKEDIN_CLIENT_SECRET=tu_linkedin_client_secret

# Analytics (opcional)
NEXT_PUBLIC_GA_ID=tu_google_analytics_id

# Stripe (pagos, cuando se implemente)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx

# Modo
NODE_ENV=development
DEBUG=false
